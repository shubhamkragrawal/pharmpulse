POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=pharmapulse
POSTGRES_USER=pharmapulse_user
POSTGRES_PASSWORD=changeme
OPENFDA_API_KEY=optional_for_higher_rate_limits

# Read-only role for the Streamlit app (marts + metrics schemas only).
# After setting this, run `make create-readonly-role` once to create the
# role in Postgres -- it is not created automatically on container init.
READONLY_PASSWORD=changeme_readonly

# Airflow admin user (webserver login) and metadata-DB connection. The
# `airflow` database lives on this same Postgres service/instance (see
# decisions.md), separate from POSTGRES_DB -- it is created automatically
# by the airflow-init service on first `make airflow-init`.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_airflow
AIRFLOW_ADMIN_EMAIL=admin@pharmapulse.local

