POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=pharmapulse
POSTGRES_USER=pharmapulse_user
POSTGRES_PASSWORD=changeme
OPENFDA_API_KEY=optional_for_higher_rate_limits

# Read-only role for the Streamlit app (marts + metrics schemas only).
# After setting this, run `make create-readonly-role` once to create the
# role in Postgres -- it is not created automatically on container init.
READONLY_PASSWORD=changeme_readonly